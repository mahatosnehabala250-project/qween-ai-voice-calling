# Vobiz Voice AI Platform - Environment Variables
# Copy this file to .env and fill in your actual values

# ==========================================
# VOBOZ TELEPHONY CONFIGURATION
# ==========================================
VOBIZ_API_KEY=your_vobiz_api_key_here
VOBIZ_SIP_DOMAIN=sip.vobiz.ai
VOBIZ_SIP_USERNAME=your_sip_username
VOBIZ_SIP_PASSWORD=your_sip_password
VOBIZ_WEBHOOK_SECRET=your_webhook_secret_here

# ==========================================
# GOOGLE GEMINI 2.5 LIVE API
# ==========================================
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-05-20
GEMINI_VOICE_ID=en-US-Standard-A
GEMINI_LANGUAGE_CODE=en-IN

# ==========================================
# SUPABASE DATABASE (Mumbai Region)
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ==========================================
# N8N AUTOMATION WEBHOOK
# ==========================================
N8N_WEBHOOK_URL=http://localhost:5678/webhook/post-call
N8N_AUTH_HEADER=Bearer your_n8n_auth_token

# ==========================================
# APPLICATION SETTINGS
# ==========================================
APP_ENV=development
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ==========================================
# BUSINESS DEFAULTS (Dental Clinic)
# ==========================================
DEFAULT_BUSINESS_TYPE=dental_clinic
DEFAULT_LANGUAGES=en-IN,hi-IN
DEFAULT_TIMEZONE=Asia/Kolkata
ESCALATION_PHONE=+919876543210
